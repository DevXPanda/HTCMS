{
  "name": "ulb-backend",
  "version": "1.0.0",
  "description": "Urban Local Bodies - Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --quiet server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:assigned-modules": "node run-migrate-assigned-modules.js",
    "migrate:worker-type": "node run-migrate-worker-type.js",
    "migrate:worker-type-other": "node run-migrate-worker-type-other.js",
    "migrate:attendance-photos": "node run-migrate-attendance-before-after-photos.js",
    "migrate:ward-number-001": "node run-migrate-ward-number-001.js",
    "seed": "sequelize-cli db:seed:all",
    "update-wcr-ids": "node scripts/update-water-connection-request-ids.js"
  },
  "keywords": [
    "ulb",
    "tax",
    "management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "razorpay": "^2.9.2",
    "react-barcode": "^1.6.1",
    "sequelize": "^6.35.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2"
  }
}
